# ============================================================================
# Environment variables for the Guided Essay Writing app
# ============================================================================
# Copy the relevant values into your Netlify site's environment variables
# (Site settings → Environment variables). This file documents the contract;
# it must NOT contain real secrets. Do not commit a filled-in .env.
#
# NOTE: this app has no local build. `netlify dev` reads these when running
# the functions locally; in production Netlify injects them.

# ── AI (required) ───────────────────────────────────────────────────────────
# Anthropic API key used by all grading / generation functions.
ANTHROPIC_API_KEY=sk-ant-...

# ── Firebase Admin SDK (required — server-side, used by the functions) ───────
# From a Firebase service-account key (Project settings → Service accounts).
# FIREBASE_PRIVATE_KEY must keep its literal \n escapes; the code un-escapes them.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Firebase Web config (required — served to the browser by the ─────────────
#    firebase-config function; these are public-by-design identifiers, not
#    secrets, except the API key which is still restricted at the Firebase end).
# Each also accepts an ENV_-prefixed fallback name (e.g. ENV_FIREBASE_API_KEY).
FIREBASE_API_KEY=your-web-api-key
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
# FIREBASE_PROJECT_ID is reused from the Admin SDK section above.

# ── CORS (optional) ──────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the functions. If unset, the
# functions fall back to '*'. Set this to your production origin(s) to lock down.
# ALLOWED_ORIGINS=https://your-site.netlify.app

# ── CI: Firestore rules deploy (set as a GitHub Actions secret, not here) ────
# FIREBASE_SERVICE_ACCOUNT — full service-account JSON, used by
# .github/workflows/deploy-firestore-rules.yml to deploy firestore.rules.
