{
  "name": "essay-writer-multi",
  "version": "6.0.0",
  "description": "Guided essay-writing platform: students write essays paragraph-by-paragraph with AI feedback; teachers manage classes, students, and essays via a dashboard. Netlify Functions + Firestore + Claude.",
  "private": true,
  "scripts": {
    "start": "npx serve .",
    "build": "vite build",
    "test": "npm run test:smoke",
    "test:smoke": "vite build && node test/smoke.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@netlify/blobs": "^8.1.0",
    "firebase-admin": "^12.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "essay-writing",
    "education",
    "ai-grading",
    "netlify",
    "firebase",
    "claude"
  ],
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "dompurify": "^3.1.6",
    "firebase": "^10.7.1",
    "marked": "^12.0.2",
    "pdfjs-dist": "^3.11.174",
    "playwright-core": "^1.48.0",
    "vite": "^5.4.11"
  }
}
