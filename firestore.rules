rules_version = '2';

// ============================================================================
// Firestore security rules — INTERIM (authentication-required)
// ============================================================================
//
// This REPLACES the catastrophic `allow read, write: if true` that left the
// entire database world-readable and -writable via the public web config.
//
// It is safe to deploy to the live app: students and teachers sign into
// Firebase Auth on login (index.html signInWithEmailAndPassword), so their
// browser holds a Firebase Auth session and `request.auth != null` is true for
// every path the client legitimately uses.
//
// All privileged/server logic runs through Netlify functions using the Firebase
// Admin SDK, which bypasses these rules entirely — so tightening them here does
// not affect the functions.
//
// ── RESIDUAL (to be closed in Phase 3 / IMPROVEMENT_PLAN.md) ────────────────
// Any authenticated user can still read/write ANY document in the
// client-accessible collections below (e.g. one student could read another
// student's submission directly from the browser console). Also, `students`
// docs carry a passwordHash field and Firestore rules cannot hide a single
// field on read, so an authed user could read other users' PBKDF2 hashes.
// The end state is per-document ownership rules once the remaining direct
// client reads are migrated to the authenticated functions, after which these
// collections can move to deny-all (server-only) like the ones below.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Server-only collections ───────────────────────────────────────────
    // Only the Netlify functions (Admin SDK) touch these. The browser must
    // never read them: exposing session tokens would enable session hijacking,
    // and the rate-limit counters are internal. Deny all client access.
    match /sessions/{doc}        { allow read, write: if false; }
    match /teacherSessions/{doc} { allow read, write: if false; }
    match /teachers/{doc}        { allow read, write: if false; }
    match /rateLimits/{doc}      { allow read, write: if false; }

    // ── Client-accessible collections (require authentication) ─────────────
    // The app reads/writes these directly from the browser for logged-in
    // users. Require a Firebase Auth session; deny anonymous access.
    match /students/{doc}    { allow read, write: if request.auth != null; }
    match /classes/{doc}     { allow read, write: if request.auth != null; }
    match /essays/{doc}      { allow read, write: if request.auth != null; }
    match /submissions/{doc} { allow read, write: if request.auth != null; }
    match /progress/{doc}    { allow read, write: if request.auth != null; }

    // Default: deny anything not explicitly matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
